                  "pm.test(\"HTTP 状态为 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"业务码为 200\", function () {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test(\"返回计算摘要字段\", function () {",
                  "  pm.expect(json.data).to.be.an(\"object\");",
                  "  pm.expect(json.data.hourCount).to.be.a(\"number\");",
                  "  pm.expect(json.data.riskRowCount).to.be.a(\"number\");",
                  "  pm.expect(json.data.speedRowCount).to.be.a(\"number\");",
                  "});"
