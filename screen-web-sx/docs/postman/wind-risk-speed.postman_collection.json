      "name": "Positive Cases",
      "item": [
        {
          "name": "01 Calculate And Persist",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"HTTP 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Business code is 200\", function () {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test(\"Has calculation summary\", function () {",
                  "  pm.expect(json.data).to.be.an(\"object\");",
                  "  pm.expect(json.data.hourCount).to.be.a(\"number\");",
                  "  pm.expect(json.data.riskRowCount).to.be.a(\"number\");",
                  "  pm.expect(json.data.speedRowCount).to.be.a(\"number\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
