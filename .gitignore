# ========================== Java 通用忽略规则 ==========================
# 编译生成的字节码文件
*.class

# 日志文件
*.log

# BlueJ 相关文件
*.ctxt

# J2ME 移动开发工具临时文件
.mtj.tmp/

# 打包文件
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JVM 崩溃日志
hs_err_pid*
replay_pid*

# Maven/Gradle 构建输出目录（核心！避免整个编译目录被提交）
target/
build/
.gradle/
gradle-app.setting
!gradle-wrapper.jar
*.jar
!*.jar
build/
!gradle/wrapper/gradle-wrapper.jar

# ========================== JetBrains IDE (IDEA) 忽略规则 ==========================
# IDE 配置目录（整体忽略，避免零散配置项漏写）
.idea/
# IDE 生成的项目文件
*.iml
*.iws
*.ipr
# IDE 编译输出目录
out/
cmake-build-*/

# IDE 插件相关
.idea/**/mongoSettings.xml
.idea/replstate.xml
.idea/sonarlint/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties
.idea/httpRequests
.idea/caches/build_file_checksums.ser

# ========================== 自定义忽略规则 ==========================
app-screen-sx-logs/