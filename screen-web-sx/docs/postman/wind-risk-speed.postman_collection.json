                  "try { body = pm.response.json(); } catch (e) {}",
                  "",
                  "pm.test(\"Request should fail\", function () {",
                  "  if (body && Object.prototype.hasOwnProperty.call(body, \"code\")) {",
                  "    pm.expect(body.code).to.not.eql(200);",
                  "  } else {",
                  "    pm.expect(pm.response.code).to.not.eql(200);",
